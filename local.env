# Telegram bot token (bot must be added to channels as admin to receive posts)
TELEGRAM_BOT_TOKEN=8076860650:AAEprRHsyLQFya7gZjQItySYtEyHHX8UsV8

# Comma-separated channel identifiers the worker is allowed to process.
# Supports chat IDs and usernames, e.g. -100123456789,@ethiotechnews
TELEGRAM_CHANNELS=-1003899150815

# Keyword-based filter for pending_events creation.
TELEGRAM_KEYWORDS=hackathon,meetup,conference,bootcamp,summit,workshop,webinar,event

# MongoDB connection used by Telegram worker.
MONGODB_URI="mongodb://anbudevdb:techventdb@ac-o7co7af-shard-00-00.vemhkxp.mongodb.net:27017,ac-o7co7af-shard-00-01.vemhkxp.mongodb.net:27017,ac-o7co7af-shard-00-02.vemhkxp.mongodb.net:27017/?ssl=true&replicaSet=atlas-5f9prx-shard-0&authSource=admin&appName=Cluster0"
MONGODB_DB=test

# Optional Telegram chat ID that receives "new pending event" notifications.
APPROVAL_NOTIFY_CHAT_ID=6882331272

# Polling delay after errors (seconds).
POLL_INTERVAL_SECONDS=5

# Long polling timeout passed to getUpdates.
TELEGRAM_LONG_POLL_TIMEOUT_SECONDS=25

# Print detailed per-step logs.
VERBOSE_LOGGING=true

# If true, worker clears Telegram webhook before polling (fixes 409 conflicts).
AUTO_DELETE_WEBHOOK_ON_START=true